<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Our Constellation</title>

<!-- خط جميل -->
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&display=swap" rel="stylesheet">

<style>
body{
    margin:0;
    overflow:hidden;
    height:100vh;
    font-family:'Cinzel', serif;

    /* سما طبيعية أكتر */
    background: radial-gradient(circle at top, #1b3c6b, #0b1c33 70%, #050914);
}

/* النجوم */
.star{
    position:absolute;
    font-size:16px; /* أصغر */
    cursor:pointer;
    animation:twinkle 2s infinite alternate;
    user-select:none;
    filter: drop-shadow(0 0 6px gold);
}

@keyframes twinkle{
    from{transform:scale(1); opacity:.7;}
    to{transform:scale(1.3); opacity:1;}
}

/* popup */
#popup{
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    width:85%;
    max-width:500px;
    background:rgba(10,15,30,.95);
    border:1px solid gold;
    color:white;
    padding:25px;
    border-radius:15px;
    display:none;
    text-align:center;
    box-shadow:0 0 30px gold;
}

#popup h2{color:gold;}

button{
    margin-top:15px;
    padding:8px 15px;
    border:none;
    border-radius:8px;
    background:gold;
    font-weight:bold;
}

/* العنوان */
.title{
    position:absolute;
    top:25px;
    width:100%;
    text-align:center;
    color:white;
    font-size:1.8rem;
}

.subtitle{
    position:absolute;
    top:65px;
    width:100%;
    text-align:center;
    color:#ddd;
    font-size:1rem;
}
</style>
</head>

<body>

<div class="title">HBD, Love 🪷</div>

<!-- موسيقى -->
<audio id="music" loop>
    <source src="music.mp3" type="audio/mp3">
</audio>

<!-- ⭐ النجوم -->
<div class="star" style="top:20%;left:15%;" onclick="showMessage(0)">⭐</div>
<div class="star" style="top:30%;left:60%;" onclick="showMessage(1)">⭐</div>
<div class="star" style="top:25%;left:80%;" onclick="showMessage(2)">⭐</div>
<div class="star" style="top:50%;left:25%;" onclick="showMessage(3)">⭐</div>
<div class="star" style="top:60%;left:70%;" onclick="showMessage(4)">⭐</div>
<div class="star" style="top:40%;left:45%;" onclick="showMessage(5)">⭐</div>
<div class="star" style="top:75%;left:15%;" onclick="showMessage(6)">⭐</div>
<div class="star" style="top:78%;left:85%;" onclick="showMessage(7)">⭐</div>
<div class="star" style="top:65%;left:45%;" onclick="showMessage(8)">⭐</div>
<div class="star" style="top:15%;left:50%;" onclick="showMessage(9)">⭐</div>

<div id="popup">
    <h2 id="date"></h2>
    <p id="text"></p>
    <button onclick="closePopup()">Close</button>
</div>

<script>

const memories = [
{date:"16Jul2024", text:"Hi buddy?"},
{date:"29sep2024", text:"BOYFRIENDS (finally)"},
{date:"22Jul2024", text:"I think I like you,maybe"},
{date:"27Jul2024", text:"I'll sing for you for free, any one else can pay"},
{date:"1may2026", text:"A mom returns to her lost child (fuck you)"},
{date:"27may2026", text:"BOYFRIENDS AGAIN YAYY"},
{date:"6jun2026", text:"you said you're trying for me, and I really love that"},
{date:"19jun2026", text:"I got my johna!! (that's a win and important date yup)"},
{date:"1jan2025", text:"kokito!! (we made this up but whatever"},
{date:"1Jul2005", text:"We make a full moon yk? Waning&Waxing crescent moon"}
];

function showMessage(i){
document.getElementById("date").innerText = memories[i].date;
document.getElementById("text").innerText = memories[i].text;
document.getElementById("popup").style.display = "block";

/* تشغيل الموسيقى عند أول ضغط */
document.getElementById("music").play();
}

function closePopup(){
document.getElementById("popup").style.display = "none";
}

</script>

</body>
</html>
